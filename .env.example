# App
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
SESSION_SECRET=replace-with-at-least-32-characters

# Auth
AUTH_MODE=saml # saml | dev_bypass
AUTH_DEV_BYPASS=false
AUTH_DEV_DEFAULT_ROLE=uploader

# SAML Service Provider (Spotlight SP)
# TODO(client-confirm): set SAML_SP_ENTITY_ID explicitly for each deployed environment if metadata endpoint is not desired.
SAML_SP_ENTITY_ID=
SAML_SP_ACS_PATH=/api/auth/saml/callback
SAML_SP_SLO_PATH=/api/auth/saml/logout
SAML_SP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME_IF_SIGNING_ENABLED\n-----END PRIVATE KEY-----"
SAML_SP_PUBLIC_CERT="-----BEGIN CERTIFICATE-----\nREPLACE_ME_IF_SIGNING_ENABLED\n-----END CERTIFICATE-----"

# SAML Identity Provider (ForgeRock/TMNA from provided metadata)
SAML_IDP_ENTITY_ID=https://ep.fram.qa.idm.toyota.com/Spotlight
SAML_IDP_SSO_URL=https://ep.fram.qa.idm.toyota.com/openam/SSORedirect/metaAlias/dealerdaily/Spotlight
SAML_IDP_SLO_URL=https://ep.fram.qa.idm.toyota.com/openam/IDPSloRedirect/metaAlias/dealerdaily/Spotlight
# IMPORTANT: paste the exact X.509 signing certificate from client-provided metadata
SAML_IDP_PUBLIC_CERT="-----BEGIN CERTIFICATE-----\nPASTE_FORGEROCK_METADATA_CERT_HERE\n-----END CERTIFICATE-----"

# Optional override map for incoming attribute names
SAML_ATTR_EMPLOYEE_ID=employeeId
SAML_ATTR_EMAIL=email
SAML_ATTR_NAME=displayName
SAML_ATTR_ROLE=role
SAML_ATTR_HOME_AREA=homeArea

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/spotlight?schema=public
